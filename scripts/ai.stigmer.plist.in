<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>ai.stigmer</string>
  <key>ProgramArguments</key>
  <array>
    <string>@STIGMER_ROOT@/scripts/stigmer</string>
    <string>start</string>
  </array>
  <key>WorkingDirectory</key>
  <string>@STIGMER_ROOT@</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>STIGMER_DAEMON_QUIET</key>
    <string>1</string>
  </dict>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <false/>
  <key>StandardOutPath</key>
  <string>@STIGMER_ROOT@/logs/stigmer.out.log</string>
  <key>StandardErrorPath</key>
  <string>@STIGMER_ROOT@/logs/stigmer.err.log</string>
</dict>
</plist>
