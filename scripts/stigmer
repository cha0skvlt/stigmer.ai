#!/usr/bin/env bash
# stigmer.ai — start/stop STIGMER AI Docker stack (systemd / launchd / manual).
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

LOG_DIR="${STIGMER_LOG_DIR:-$ROOT/logs}"
LOG_FILE="${STIGMER_LOG_FILE:-$LOG_DIR/stigmer.log}"

resolve_docker() {
  local d="${STIGMER_DOCKER_BIN:-}"
  if [[ -n "$d" && -x "$d" ]]; then
    printf '%s' "$d"
    return 0
  fi
  d="$(command -v docker 2>/dev/null || true)"
  if [[ -n "$d" && -x "$d" ]]; then
    printf '%s' "$d"
    return 0
  fi
  for d in /opt/homebrew/bin/docker /usr/local/bin/docker; do
    if [[ -x "$d" ]]; then
      printf '%s' "$d"
      return 0
    fi
  done
  return 1
}

DOCKER_BIN="$(resolve_docker || true)"
if [[ -z "$DOCKER_BIN" ]]; then
  echo "ERROR: docker not found (PATH=$PATH). If running from launchd, set PATH or STIGMER_DOCKER_BIN." >&2
  exit 1
fi

COMPOSE=("$DOCKER_BIN" compose -p stigmer -f docker-compose.yml)

mkdir -p "$LOG_DIR"

log() {
  local msg="[$(date '+%Y-%m-%d %H:%M:%S')] $*"
  printf '%s\n' "$msg" >>"$LOG_FILE"
  if [[ "${STIGMER_DAEMON_QUIET:-}" != "1" ]]; then
    printf '%s\n' "$msg"
  fi
}

load_env() {
  if [[ ! -f .env ]]; then
    log "Creating .env from .env.example"
    cp .env.example .env
  fi
  set -a
  # shellcheck disable=SC1091
  source .env
  set +a
}

wait_for_url() {
  local url="$1" label="$2" tries="${3:-120}"
  for ((i = 1; i <= tries; i++)); do
    if curl -sf "$url" >/dev/null 2>&1; then
      log "$label is ready"
      return 0
    fi
    sleep 1
  done
  log "ERROR: $label did not become ready ($url)"
  return 1
}

wait_for_stigmer_health() {
  local tries="${1:-120}" body
  for ((i = 1; i <= tries; i++)); do
    body="$(curl -sf http://localhost:8080/api/health 2>/dev/null || true)"
    if [[ "$body" == *'"ok":true'* ]] || [[ "$body" == *'"ok": true'* ]]; then
      log "stigmer.ai health OK"
      return 0
    fi
    sleep 1
  done
  log "ERROR: STIGMER AI not healthy on :8080 (got: ${body:-no response})"
  log "Hint: another app may be using port 8080 — stop it or run: lsof -i :8080"
  return 1
}

warn_port_8080_conflict() {
  local owner
  owner="$(lsof -nP -iTCP:8080 -sTCP:LISTEN 2>/dev/null | awk 'NR==2{print $1, $2}')"
  if [[ -n "$owner" && "$owner" != *docker* && "$owner" != *com.docke* ]]; then
    log "WARN: port 8080 already in use: $owner (not Docker — STIGMER may not bind)"
  fi
}

wait_for_docker() {
  for ((i = 1; i <= 120; i++)); do
    if "$DOCKER_BIN" info >/dev/null 2>&1; then
      log "Docker is running"
      return 0
    fi
    if [[ "$(uname -s)" == "Darwin" && $i -eq 1 ]]; then
      if [[ -d /Applications/OrbStack.app ]]; then
        log "Starting OrbStack..."
        open -a OrbStack >/dev/null 2>&1 || true
      elif [[ -d /Applications/Docker.app ]]; then
        log "Starting Docker Desktop..."
        open -a Docker >/dev/null 2>&1 || true
      fi
    fi
    sleep 1
  done
  log "ERROR: Docker did not become ready"
  return 1
}

is_ollama_mode() {
  local url="${OPENAI_BASE_URL:-}"
  local key="${OPENAI_API_KEY:-}"
  [[ "$key" == "ollama" ]] && return 0
  [[ "$url" == *":11434"* ]] && return 0
  [[ "$url" == *"localhost"* && "$url" == *"11434"* ]] && return 0
  [[ "$url" == *"127.0.0.1"* && "$url" == *"11434"* ]] && return 0
  return 1
}

ensure_ollama() {
  local base="http://127.0.0.1:11434"
  if curl -sf "$base/api/tags" >/dev/null 2>&1; then
    log "Ollama is running"
    return 0
  fi
  log "Ollama is not responding — trying to start"
  if command -v ollama >/dev/null 2>&1; then
    nohup ollama serve >>"$LOG_FILE" 2>&1 &
  elif [[ "$(uname -s)" == "Darwin" && -d /Applications/Ollama.app ]]; then
    open -a Ollama >/dev/null 2>&1 || true
  else
    log "WARN: Ollama not found — AI features may fail until Ollama is started"
    return 0
  fi
  wait_for_url "$base/api/tags" "Ollama" 90 || log "WARN: Ollama did not start in time"
}

cmd_start() {
  load_env
  wait_for_docker
  if is_ollama_mode; then
    log "Mode: local Ollama"
    ensure_ollama
  else
    log "Mode: external AI API"
  fi
  warn_port_8080_conflict
  log "Starting stigmer.ai stack..."
  if [[ "${STIGMER_DAEMON_BUILD:-1}" == "1" ]]; then
    "${COMPOSE[@]}" up --build -d >>"$LOG_FILE" 2>&1
  else
    "${COMPOSE[@]}" up -d >>"$LOG_FILE" 2>&1
  fi
  wait_for_stigmer_health 120
  log "stigmer.ai running — http://localhost:8080"
}

cmd_stop() {
  log "Stopping stigmer.ai stack..."
  "${COMPOSE[@]}" down >>"$LOG_FILE" 2>&1 || true
  log "stigmer.ai stopped"
}

cmd_status() {
  "${COMPOSE[@]}" ps
  if curl -sf http://localhost:8080/api/health >/dev/null 2>&1; then
    log "Health: OK (http://localhost:8080/api/health)"
  else
    log "Health: not responding"
    exit 1
  fi
}

cmd_restart() {
  cmd_stop
  cmd_start
}

usage() {
  cat <<EOF
Usage: stigmer {start|stop|restart|status}

  start    Wait for Docker, start stack (detached)
  stop     docker compose down
  restart  stop then start
  status   compose ps + health check

Environment:
  STIGMER_DAEMON_BUILD=0  skip image rebuild on start (default: rebuild)
  STIGMER_LOG_FILE        default: $ROOT/logs/stigmer.log
EOF
}

main() {
  local cmd="${1:-}"
  case "$cmd" in
    start) cmd_start ;;
    stop) cmd_stop ;;
    restart) cmd_restart ;;
    status) STIGMER_DAEMON_QUIET=0 cmd_status ;;
    -h|--help|help) usage ;;
    *)
      usage >&2
      exit 1
      ;;
  esac
}

main "$@"
